# Ollama host — use 127.0.0.1 for native Linux/Mac
# On WSL2, use the Windows host IP: run `cat /etc/resolv.conf | grep nameserver` to find it
OLLAMA_HOST=127.0.0.1

# Ollama model — must be pulled first: ollama pull llama3.1
OLLAMA_MODEL=llama3.1:latest

# Ollama
OLLAMA_HOST=127.0.0.1

# Email Notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=SmartAdds Notifications <your_email@gmail.com>
